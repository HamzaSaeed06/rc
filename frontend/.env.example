# Backend base URL (used for proxy in dev, and direct calls in production)
VITE_BACKEND_URL=http://localhost:3000

# API and Socket URLs (used directly by frontend services)
VITE_API_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000

# Frontend dev-server port (default: 5173)
VITE_PORT=5173

# TURN Server (required for video calls behind NAT/firewalls)
# Get free TURN from https://www.metered.ca/tools/openrelay/ or use your own
VITE_TURN_URL=turn:your-turn-server.com:3478
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_CREDENTIAL=your_turn_credential
