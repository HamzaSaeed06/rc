modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "3001"
NODE_ENV = "development"
CLIENT_URL = "http://localhost:5000"
MAX_FILE_SIZE = "10485760"
UPLOAD_PATH = "uploads/"
JWT_EXPIRES_IN = "7d"
JWT_REFRESH_EXPIRES_IN = "30d"
